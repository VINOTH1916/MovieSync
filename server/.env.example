# Copy this to .env and fill in the values
PORT=5000
MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/moviesync?retryWrites=true&w=majority
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRE=7d
CLIENT_URL=http://localhost:5173
NODE_ENV=development

# Storage
STORAGE_TYPE=local
UPLOAD_PATH=uploads
